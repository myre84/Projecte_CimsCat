# Aquest fitxer es un EXEMPLE de variables d'entorn.
# El faig servir com a plantilla per crear el fitxer real .env.

# Mode d'execucio de Node (development, production, test...)
NODE_ENV=development

# Port on escoltara el servidor Express
PORT=3000

# Clau secreta per signar i validar JWT
# IMPORTANT: en un projecte real, cal una clau llarga i privada.
JWT_SECRET=canvia_aquest_secret_super_llarg

# Credencials del contenidor PostgreSQL local
POSTGRES_USER=cimscat
POSTGRES_PASSWORD=cimscat123

# Nom de la base de dades principal del projecte
POSTGRES_DB=cimscat

# Port local que exposem per connectar-nos a Postgres
POSTGRES_PORT=5432

# URL principal que Prisma utilitza per operar sobre la base de dades
DATABASE_URL=postgresql://cimscat:cimscat123@localhost:5432/cimscat?schema=public

# URL directa per operacions de migracio (Prisma la fa servir en alguns fluxos)
DIRECT_URL=postgresql://cimscat:cimscat123@localhost:5432/cimscat?schema=public
